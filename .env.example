# Database
DATABASE_URL="postgresql://pcip:pcip_secret@localhost:5432/pcip?schema=public"

# Auth
AUTH_SECRET="generate-a-secure-random-string-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# AI Provider (openai | gemini)
AI_PROVIDER="openai"
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# S3-compatible storage
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="pcip-exports"

# App
APP_NAME="Public Contact Intelligence Platform"
APP_URL="http://localhost:3000"

# Rate limiting
RATE_LIMIT_SEARCHES_PER_MINUTE=10
RATE_LIMIT_API_PER_MINUTE=60

# Observability
LOG_LEVEL="info"
SENTRY_DSN=""
