# Database — Supabase
# Pooled connection (used by the app at runtime on Vercel — via PgBouncer)
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"
# Direct connection (used by Prisma CLI for migrations only)
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres"

# Auth
AUTH_SECRET="generate-a-secure-random-string-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# AI Provider (openai | gemini)
AI_PROVIDER="openai"
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# S3-compatible storage
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="pcip-exports"

# App
APP_NAME="Public Contact Intelligence Platform"
APP_URL="http://localhost:3000"

# Rate limiting
RATE_LIMIT_SEARCHES_PER_MINUTE=10
RATE_LIMIT_API_PER_MINUTE=60

# Observability
LOG_LEVEL="info"
SENTRY_DSN=""
